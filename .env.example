# Phishlab environment variables.
# Copy this file to .env and fill in your actual values.
# .env is gitignored and should never be committed.

# Gmail IMAP settings
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-abuse-inbox@gmail.com
IMAP_PASSWORD=your-16-char-google-app-password
IMAP_FOLDER=INBOX